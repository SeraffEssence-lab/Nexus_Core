    <script>
        const triggerZone = document.getElementById('trigger-zone');
        const textTarget = document.getElementById('text-target');

        const originalText = 'No gestionamos especulaciones comunes ni participamos en mercados fantasma. Dirigimos <strong>infraestructura digital avanzada</strong> y marcas de alta fidelidad con precisión matemática. El motor opera de forma independiente. El acceso no se compra; se otorga.';
        const proposalText = 'Multiplicamos valor real mediante algoritmos de software propio, activos de laboratorio calibrados e integraciones comerciales masivas de alta velocidad. Estás ante el nodo de tracción más rentable del cuadrante. **Aceptando participación de capital selecto por tiempo limitado.**';

        function showProposal() {
            textTarget.style.opacity = '0';
            setTimeout(() => {
                textTarget.innerHTML = proposalText;
                textTarget.classList.add('revealed');
                textTarget.style.opacity = '1';
            }, 200);
        }

        function showOriginal() {
            textTarget.style.opacity = '0';
            setTimeout(() => {
                textTarget.innerHTML = originalText;
                textTarget.classList.remove('revealed');
                textTarget.style.opacity = '1';
            }, 200);
        }

        triggerZone.addEventListener('mouseenter', showProposal);
        triggerZone.addEventListener('mouseleave', showOriginal);
        triggerZone.addEventListener('touchstart', (e) => { e.preventDefault(); showProposal(); });
    </script>
