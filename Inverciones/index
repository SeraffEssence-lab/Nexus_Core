            color: #ffffff; 
            scroll-behavior: smooth;
            overflow-x: hidden;
            letter-spacing: -0.02em;
        }

        body::before {
            content: "";
            position: fixed;
            width: 100%;
            height: 100%;
            background-image: radial-gradient(rgba(255,255,255,0.02) 1px, transparent 0);
