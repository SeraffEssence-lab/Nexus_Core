        }

        .swiss-line {
            width: 1px;
            height: 50px;
            background: linear-gradient(to bottom, transparent, #c5a880, transparent);
            margin: 0 auto 25px auto;
        }

        h1 { 
            font-size: 5rem; 
            font-weight: 900; 
            letter-spacing: 12px; 
            text-transform: uppercase;
            margin-bottom: 5px;
            padding-left: 12px;
            background: linear-gradient(180deg, #ffffff 40%, #a3a3a3 100%);
